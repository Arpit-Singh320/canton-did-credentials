module DIDTest where

import Daml.Script
import DA.Assert ((===), assert, assertMsg, assertThrows)
import DA.Date (date, Month(..), DayOfWeek(..), toDateUTC)
import DA.Text qualified as T
import DA.Time (time, addRelTime, days)

import DID.Document
import DID.Credential
import DID.Presentation
import DID.Revocation
import DID.TrustAnchor

-- | Main test suite for the DID and Verifiable Credential workflow.
didLifecycleTests = script do
  -- === Party Setup ===
  -- Allocate the main parties for our scenarios.
  trustAnchor <- allocatePartyWithHint "TrustAnchor" (PartyIdHint "trust-anchor")
  issuer      <- allocatePartyWithHint "Issuer" (PartyIdHint "issuer")
  holder      <- allocatePartyWithHint "Holder" (PartyIdHint "holder")
  verifier    <- allocatePartyWithHint "Verifier" (PartyIdHint "verifier")

  -- === DID Setup ===
  -- For testing purposes, we use a simple "did:daml:<partyId>" format.
  -- In a real system, these would be generated and resolved via a specific DID method.
  let trustAnchorDid = "did:daml:" <> T.pack (show trustAnchor)
  let issuerDid      = "did:daml:" <> T.pack (show issuer)
  let holderDid      = "did:daml:" <> T.pack (show holder)
  let verifierDid    = "did:daml:" <> T.pack (show verifier)

  -- Create the on-ledger representation of each party's DID.
  _ <- submit trustAnchor do createCmd DIDDocument with id = trustAnchorDid, controller = trustAnchor
  _ <- submit issuer      do createCmd DIDDocument with id = issuerDid,      controller = issuer
  _ <- submit holder      do createCmd DIDDocument with id = holderDid,      controller = holder
  _ <- submit verifier    do createCmd DIDDocument with id = verifierDid,    controller = verifier

  -- === Test Scenarios ===

  test "Successful Issuance, Presentation, and Verification" do
    -- 1. Trust Anchor establishes a Trust Registry and adds the Issuer.
    trustRegistryCid <- submit trustAnchor do
      createCmd TrustRegistry with anchor = trustAnchor, trustedIssuers = []
    updatedTrustRegistryCid <- submit trustAnchor do
      exerciseCmd trustRegistryCid AddTrustedIssuer with issuerDid

    -- 2. Issuer establishes a Revocation Registry for credentials it issues.
    revocationRegistryCid <- submit issuer do
      createCmd RevocationRegistry with issuer, revokedCredentialIds = []

    -- 3. Issuer offers a "KYC" credential to the Holder.
    let
      credentialSubject = [ ("country", "US"), ("isAccredited", "true") ]
      issuanceDate = time (date 2024 Jan 1) 0 0 0
      expirationDate = Some $ date 2030 Jan 1

    offerCid <- submit issuer do
      createCmd CredentialOffer with
        issuer
        holder
        credentialType = "KYC"
        credentialSubject
        issuanceDate
        expirationDate
        revocationRegistryCid = Some revocationRegistryCid

    -- 4. Holder accepts the offer, creating a VerifiableCredential contract.
    (vcCid, vc) <- submit holder do
      exerciseCmd offerCid AcceptCredentialOffer with holderDid

    -- Assertions to check the created credential's data.
    vc.issuer === issuerDid
    vc.holder === holderDid
    vc.credentialType === "KYC"
    vc.credentialSubject === credentialSubject

    -- 5. Verifier requests a presentation of a "KYC" credential from the Holder.
    requestCid <- submit verifier do
      createCmd PresentationRequest with
        verifier
        holder
        requestedCredentialType = "KYC"

    -- 6. Holder fulfills the request by creating a VerifiablePresentation.
    presentationCid <- submit holder do
      exerciseCmd requestCid FulfillPresentationRequest with
        credentialCid = vcCid
        trustRegistryCid = updatedTrustRegistryCid

    -- 7. Verifier verifies the presentation. This should succeed.
    verificationResult <- submit verifier do
      exerciseCmd presentationCid VerifyPresentation

    verificationResult.verified === True
    verificationResult.reason === "Presentation verified successfully."

  test "Revocation prevents successful verification" do
    -- 1. Setup registries. Issuer is already trusted.
    trustRegistryCid <- submit trustAnchor do
      createCmd TrustRegistry with anchor = trustAnchor, trustedIssuers = [issuerDid]
    revocationRegistryCid <- submit issuer do
      createCmd RevocationRegistry with issuer, revokedCredentialIds = []

    -- 2. Issuer issues a credential to the Holder.
    let
      credentialSubject = [ ("clearanceLevel", "TopSecret") ]
      issuanceDate = time (date 2024 Jan 1) 0 0 0
      expirationDate = Some $ date 2030 Jan 1
    offerCid <- submit issuer do
      createCmd CredentialOffer with
        issuer, holder, credentialType = "SecurityClearance",
        credentialSubject, issuanceDate, expirationDate,
        revocationRegistryCid = Some revocationRegistryCid

    (vcCid, vc) <- submit holder do exerciseCmd offerCid AcceptCredentialOffer with holderDid

    -- 3. Issuer revokes the credential by adding its ID to the registry.
    updatedRevocationRegistryCid <- submit issuer do
      exerciseCmd revocationRegistryCid RevokeCredential with credentialIdToRevoke = vc.id

    -- 4. Verifier requests a presentation.
    requestCid <- submit verifier do
      createCmd PresentationRequest with
        verifier, holder, requestedCredentialType = "SecurityClearance"

    -- 5. Holder presents the (now revoked) credential.
    presentationCid <- submit holder do
      exerciseCmd requestCid FulfillPresentationRequest with
        credentialCid = vcCid
        trustRegistryCid

    -- 6. Verifier attempts verification, which must fail due to revocation.
    verificationResult <- submit verifier do
      exerciseCmd presentationCid VerifyPresentation

    verificationResult.verified === False
    assert (T.isPrefixOf "Credential has been revoked." verificationResult.reason)

  test "Verification fails for untrusted issuer" do
    -- 1. Setup a new, untrusted issuer.
    untrustedIssuer <- allocatePartyWithHint "UntrustedIssuer" (PartyIdHint "untrusted-issuer")
    let untrustedIssuerDid = "did:daml:" <> T.pack (show untrustedIssuer)
    _ <- submit untrustedIssuer do createCmd DIDDocument with id = untrustedIssuerDid, controller = untrustedIssuer

    -- 2. Trust registry only trusts the original, good issuer.
    trustRegistryCid <- submit trustAnchor do
      createCmd TrustRegistry with anchor = trustAnchor, trustedIssuers = [issuerDid]

    -- 3. Untrusted issuer issues a credential to the Holder.
    offerCid <- submit untrustedIssuer do
      createCmd CredentialOffer with
        issuer = untrustedIssuer, holder,
        credentialType = "FakeDiploma",
        credentialSubject = [("degree", "PhD in Damlology")],
        issuanceDate = time (date 2024 Jan 1) 0 0 0,
        expirationDate = None, revocationRegistryCid = None

    (vcCid, _) <- submit holder do exerciseCmd offerCid AcceptCredentialOffer with holderDid

    -- 4. Verifier requests the credential.
    requestCid <- submit verifier do
      createCmd PresentationRequest with
        verifier, holder, requestedCredentialType = "FakeDiploma"

    -- 5. Holder presents the credential from the untrusted source.
    presentationCid <- submit holder do
      exerciseCmd requestCid FulfillPresentationRequest with
        credentialCid = vcCid
        trustRegistryCid

    -- 6. Verifier's attempt to verify must fail as the issuer is unknown.
    verificationResult <- submit verifier do
      exerciseCmd presentationCid VerifyPresentation

    verificationResult.verified === False
    verificationResult.reason === "Issuer is not in the Trust Registry."

  test "Verification fails for expired credential" do
    -- 1. Setup trust registry.
    trustRegistryCid <- submit trustAnchor do
      createCmd TrustRegistry with anchor = trustAnchor, trustedIssuers = [issuerDid]

    -- 2. Get current time and calculate a past date for expiration.
    now <- getTime
    let pastDate = addRelTime now (days (-1))

    -- 3. Issuer issues a credential that has already expired.
    offerCid <- submit issuer do
      createCmd CredentialOffer with
        issuer, holder, credentialType = "TemporaryPass",
        credentialSubject = [("access", "granted")],
        issuanceDate = addRelTime now (days (-2)),
        expirationDate = Some (toDateUTC pastDate),
        revocationRegistryCid = None

    (vcCid, _) <- submit holder do exerciseCmd offerCid AcceptCredentialOffer with holderDid

    -- 4. Verifier requests the credential.
    requestCid <- submit verifier do
      createCmd PresentationRequest with
        verifier, holder, requestedCredentialType = "TemporaryPass"

    -- 5. Holder presents the expired credential.
    presentationCid <- submit holder do
      exerciseCmd requestCid FulfillPresentationRequest with
        credentialCid = vcCid
        trustRegistryCid

    -- 6. Verification must fail due to expiration.
    verificationResult <- submit verifier do
      exerciseCmd presentationCid VerifyPresentation

    verificationResult.verified === False
    verificationResult.reason === "Credential has expired."

  test "Presentation fulfillment fails for mismatched credential type" do
    -- 1. Setup trust registry.
    trustRegistryCid <- submit trustAnchor do
      createCmd TrustRegistry with anchor = trustAnchor, trustedIssuers = [issuerDid]

    -- 2. Issuer issues a "KYC" credential.
    offerCid <- submit issuer do
      createCmd CredentialOffer with
        issuer, holder, credentialType = "KYC",
        credentialSubject = [("country", "CH")],
        issuanceDate = time (date 2024 Jan 1) 0 0 0,
        expirationDate = None, revocationRegistryCid = None

    (vcCid, _) <- submit holder do exerciseCmd offerCid AcceptCredentialOffer with holderDid

    -- 3. Verifier requests a different type: "Accreditation".
    requestCid <- submit verifier do
      createCmd PresentationRequest with
        verifier, holder, requestedCredentialType = "Accreditation"

    -- 4. Holder's attempt to fulfill with the wrong credential type must fail.
    submitMustFail holder do
      exerciseCmd requestCid FulfillPresentationRequest with
        credentialCid = vcCid
        trustRegistryCid

  test "Non-controller cannot create DID Document for another party" do
    -- 1. Allocate a rogue party.
    rogueParty <- allocatePartyWithHint "Rogue" (PartyIdHint "rogue")

    -- 2. Define a DID for the legitimate holder.
    let targetDid = "did:daml:" <> T.pack (show holder)

    -- 3. The rogue party's attempt to create a DID document where the
    --    controller is `holder` must fail, as `rogueParty` is not a
    --    signatory on the resulting contract.
    submitMustFail rogueParty do
      createCmd DIDDocument with
        id = targetDid,
        controller = holder