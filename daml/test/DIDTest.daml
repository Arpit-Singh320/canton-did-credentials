module Credentials.Test.DIDTest where

import Daml.Script
import DA.Assert
import DA.Date as D
import DA.Time (time, addRelTime, days)
import DA.Map (fromList)

import Credentials.DID.V1 as DID
import Credentials.Credential.V1 as Credential
import Credentials.Presentation.V1 as Presentation
import Credentials.Revocation.V1 as Revocation

-- === Test Scenarios ===

didTests : Script ()
didTests = script do
  -- Party setup
  issuerParty <- allocatePartyWithHint "Issuer" (PartyIdHint "issuer")
  holderParty <- allocatePartyWithHint "Holder" (PartyIdHint "holder")
  verifierParty <- allocatePartyWithHint "Verifier" (PartyIdHint "verifier")
  anotherIssuerParty <- allocatePartyWithHint "AnotherIssuer" (PartyIdHint "another-issuer")

  -- Run tests sequentially
  testGroup "Verifiable Credentials Lifecycle" do
    test "Happy Path: Issue, Present, and Verify a Credential" do
      runLifecycleTest issuerParty holderParty verifierParty

    test "Revocation: Verifying a revoked credential must fail" do
      runRevocationTest issuerParty holderParty verifierParty

    test "Invalid Presentation: Presenting a credential that does not match the request" do
      runInvalidPresentationTest issuerParty holderParty verifierParty anotherIssuerParty

    test "Invalid Holder: Holder cannot present someone else's credential" do
      runInvalidHolderTest issuerParty holderParty verifierParty

-- === Full Lifecycle Test ===

runLifecycleTest : Party -> Party -> Party -> Script ()
runLifecycleTest issuer holder verifier = do
  -- 1. Setup DID
  let holderDid = "did:canton:holder-" <> show holder
  didCid <- submit holder do
    createCmd DID.Did with
      owner = holder
      did = holderDid
      controllers = [holder]
      observers = []

  -- 2. Issue a KYC Credential
  let
    credentialId = "kyc-credential-123"
    credentialType = "KycCredential"
    issuanceDate = time (D.date 2024 D.Jan 1) 0 0 0
    expirationDate = Some (time (D.date 2025 D.Jan 1) 0 0 0)
    claims = fromList [("country", "CH"), ("level", "high")]

  -- Issuer proposes the credential
  requestCid <- submit issuer do
    createCmd Credential.CredentialRequest with
      issuer
      holder
      id = credentialId
      credentialType
      credentialSubject = holderDid
      claims
      issuanceDate
      expirationDate

  -- Holder accepts and receives the credential
  vcCid <- submit holder do
    exerciseCmd requestCid CredentialRequest_Accept

  -- 3. Verifier requests a presentation
  let presentationId = "presentation-request-456"
  presentationRequestCid <- submit verifier do
    createCmd Presentation.PresentationRequest with
      verifier
      holder
      id = presentationId
      requiredIssuer = Some issuer
      requiredType = Some credentialType
      requiredClaims = ["country"]

  -- 4. Holder presents the credential
  presentationCid <- submit holder do
    exerciseCmd presentationRequestCid PresentationRequest_Present with
      vcCid

  -- 5. Verifier verifies the presentation
  -- For this happy path, we assume no revocation registry is needed for verification.
  -- In a real system, the verifier would discover the issuer's registry.
  verificationResultCid <- submit verifier do
    exerciseCmd presentationCid VerifiablePresentation_Verify with
      revocationRegistryCid = None

  -- 6. Assert success
  result <- submit verifier do
    fetchCmd verificationResultCid

  assertMsg "Verification should be successful" result.verified
  assertMsg "Reason should be None for successful verification" (result.reason == None)

  pure ()

-- === Revocation Test ===

runRevocationTest : Party -> Party -> Party -> Script ()
runRevocationTest issuer holder verifier = do
  -- 1. Setup DID & Issue Credential (same as lifecycle test)
  let holderDid = "did:canton:holder-revocation-" <> show holder
  didCid <- submit holder do createCmd DID.Did with owner = holder, did = holderDid, controllers = [holder], observers = []

  let
    credentialId = "revocable-credential-789"
    credentialType = "AccessPass"
    issuanceDate = time (D.date 2024 D.Jan 1) 0 0 0
    claims = fromList [("area", "RestrictedZone")]

  requestCid <- submit issuer do
    createCmd Credential.CredentialRequest with issuer, holder, id = credentialId, credentialType, credentialSubject = holderDid, claims, issuanceDate, expirationDate = None
  vcCid <- submit holder do exerciseCmd requestCid CredentialRequest_Accept

  -- 2. Issuer creates a revocation registry
  registryCid <- submit issuer do
    createCmd Revocation.RevocationRegistry with
      issuer
      observers = []

  -- 3. Issuer revokes the credential
  revocationTime <- getTime
  updatedRegistryCid <- submit issuer do
    exerciseCmd registryCid RevocationRegistry_Revoke with
      credentialId
      revocationTime

  -- 4. Verifier requests presentation
  presentationRequestCid <- submit verifier do
    createCmd Presentation.PresentationRequest with
      verifier
      holder
      id = "revocation-check-presentation"
      requiredIssuer = Some issuer
      requiredType = Some credentialType
      requiredClaims = []

  -- 5. Holder presents the (now revoked) credential
  presentationCid <- submit holder do
    exerciseCmd presentationRequestCid PresentationRequest_Present with
      vcCid

  -- 6. Verifier attempts to verify the presentation, providing the revocation registry
  verificationResultCid <- submit verifier do
    exerciseCmd presentationCid VerifiablePresentation_Verify with
      revocationRegistryCid = Some updatedRegistryCid

  -- 7. Assert failure
  result <- submit verifier do fetchCmd verificationResultCid

  assertMsg "Verification should fail for a revoked credential" (not result.verified)
  assertMsg "Reason should indicate revocation" (result.reason == Some "Credential has been revoked.")

  pure ()

-- === Invalid Presentation Test ===

runInvalidPresentationTest : Party -> Party -> Party -> Party -> Script ()
runInvalidPresentationTest issuer holder verifier anotherIssuer = do
  -- 1. Setup DID & Issue Credential
  let holderDid = "did:canton:holder-invalid-" <> show holder
  didCid <- submit holder do createCmd DID.Did with owner = holder, did = holderDid, controllers = [holder], observers = []
  
  let
    credentialId = "kyc-credential-abc"
    credentialType = "KycCredential"
    issuanceDate = time (D.date 2024 D.Feb 1) 0 0 0
    claims = fromList [("country", "US")]

  requestCid <- submit issuer do
    createCmd Credential.CredentialRequest with issuer, holder, id = credentialId, credentialType, credentialSubject = holderDid, claims, issuanceDate, expirationDate = None
  vcCid <- submit holder do exerciseCmd requestCid CredentialRequest_Accept

  -- 2. Verifier requests a presentation from a DIFFERENT issuer
  presentationRequestCid <- submit verifier do
    createCmd Presentation.PresentationRequest with
      verifier
      holder
      id = "wrong-issuer-request"
      requiredIssuer = Some anotherIssuer
      requiredType = Some credentialType
      requiredClaims = []

  -- 3. Holder attempts to present the wrong credential
  -- This submission is expected to fail.
  submitMustFail holder do
    exerciseCmd presentationRequestCid PresentationRequest_Present with
      vcCid

  pure ()

-- === Invalid Holder Test ===

runInvalidHolderTest : Party -> Party -> Party -> Script ()
runInvalidHolderTest issuer holder verifier = do
  -- Setup: Need two potential holders
  realHolder <- allocatePartyWithHint "RealHolder" (PartyIdHint "real-holder")
  fakeHolder <- allocatePartyWithHint "FakeHolder" (PartyIdHint "fake-holder")

  -- 1. Issue a credential to the real holder
  let holderDid = "did:canton:real-holder-" <> show realHolder
  didCid <- submit realHolder do createCmd DID.Did with owner = realHolder, did = holderDid, controllers = [realHolder], observers = []
  
  let
    credentialId = "exclusive-credential"
    credentialType = "MembershipCard"
    issuanceDate = time (D.date 2024 Mar 1) 0 0 0
    claims = fromList [("level", "gold")]

  requestCid <- submit issuer do
    createCmd Credential.CredentialRequest with issuer, holder = realHolder, id = credentialId, credentialType, credentialSubject = holderDid, claims, issuanceDate, expirationDate = None
  vcCid <- submit realHolder do exerciseCmd requestCid CredentialRequest_Accept

  -- 2. Verifier requests a presentation from the FAKE holder
  presentationRequestCid <- submit verifier do
    createCmd Presentation.PresentationRequest with
      verifier
      holder = fakeHolder
      id = "impersonation-request"
      requiredIssuer = Some issuer
      requiredType = Some credentialType
      requiredClaims = []

  -- 3. The FAKE holder attempts to present the REAL holder's credential
  -- This should fail because the fake holder is not a stakeholder on the real VC.
  -- The ledger will prevent fetching/using a contract where the party is not a stakeholder.
  submitMustFail fakeHolder do
    exerciseCmd presentationRequestCid PresentationRequest_Present with
      vcCid
  
  pure ()